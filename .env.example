# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase.
# Encontre estas credenciais em: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Variáveis para E2E autenticado (opcional — necessário apenas para rodar npm run test:e2e com login)
TEST_EMAIL=seu-usuario@email.com
TEST_PASSWORD=sua-senha
